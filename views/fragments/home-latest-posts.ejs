<% posts.forEach((post) => { %>
  <div class="card h-100 blog-card">
    <% if (post.heroImage) { %>
      <div class="blog-card__media">
        <img src="<%= post.heroImage %>" class="card-img-top" alt="<%= post.title %>" loading="lazy" />
      </div>
    <% } %>
    <div class="card-body d-flex flex-column">
      <div class="small text-muted mb-1"><%= new Date(post.pubDate).toLocaleDateString('sv-SE') %></div>
      <h3 class="h6 fw-bold text-dark"><%= post.title %></h3>
      <p class="text-muted flex-grow-1"><%= post.description %></p>
      <a class="btn btn-outline-success mt-auto" href="/blog/<%= post.slug %>/">Soma zaidi</a>
    </div>
  </div>
<% }) %>

<% if (hasMore) { %>
  <div id="home-latest-posts-more" class="home-posts-load-more">
    <button class="btn btn-outline-success"
      type="button"
      hx-get="/fragments/latest-posts?offset=<%= nextOffset %>&limit=<%= limit %>"
      hx-target="#home-latest-posts-more"
      hx-swap="outerHTML"
      hx-indicator="#home-latest-posts-spinner">
      <span id="home-latest-posts-spinner" class="spinner-border spinner-border-sm htmx-indicator" aria-hidden="true"></span>
      Pakia makala zaidi
    </button>
  </div>
<% } %>
